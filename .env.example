# Flask secret key — CHANGE THIS in production
FLASK_SECRET_KEY=change-me-in-production

# Maximum number of items returned by the MFWS view endpoint (default: 50000)
MFWS_VIEW_LIMIT=50000

# Optional: path to a text file containing default M-Files credentials
# Supports NetworkAddress, UserName, Password, and LogInToVault fields.
# Leave empty or unset to skip auto-fill on the login form.
MFWS_DEFAULTS_FILE=

# Directory where direct-download jobs save files (default: ./downloads)
DOWNLOAD_DIR=./downloads
